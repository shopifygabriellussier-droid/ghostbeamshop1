    --carbon: #0e0e18;
    --panel: #12121f;
    --violet: #9B30FF;
    --violet-dim: #6B1FBF;
    --cyan: #00F0FF;
    --white: #F0F4FF;
    --muted: #7a7a9a;
    --glow-v: rgba(155,48,255,0.35);
    --glow-c: rgba(0,240,255,0.25);
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--void);
    color: var(--white);
    font-family: 'Inter', sans-serif;
    overflow-x: hidden;
  }

  /* ── NAVBAR ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 40px;
    background: rgba(6,6,8,0.75);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(155,48,255,0.15);
  }

  .logo {
    font-family: 'Orbitron', monospace;
    font-weight: 900;
    font-size: 1.2rem;
    letter-spacing: 0.1em;
    color: var(--white);
  }
  .logo span { color: var(--violet); }

  .nav-cta {
    background: var(--violet);
    color: #fff;
    border: none;
    padding: 10px 24px;
    font-family: 'Orbitron', monospace;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
    transition: background 0.2s, box-shadow 0.2s;
  }
  .nav-cta:hover {
    background: #b44fff;
    box-shadow: 0 0 24px var(--glow-v);
  }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 120px 24px 80px;
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 80%, rgba(155,48,255,0.28) 0%, transparent 70%),
      radial-gradient(ellipse 40% 30% at 20% 60%, rgba(0,240,255,0.12) 0%, transparent 60%),
      linear-gradient(180deg, #060608 0%, #0a0a18 100%);
    animation: breathe 6s ease-in-out infinite;
  }

  @keyframes breathe {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.75; }
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--violet);
    color: var(--violet);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 6px 16px;
    margin-bottom: 28px;
    position: relative;
    z-index: 1;
  }
  .badge::before { content: ''; width: 6px; height: 6px; background: var(--violet); border-radius: 50%; animation: pulse-dot 2s infinite; }
  @keyframes pulse-dot { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(1.4)} }

  .hero h1 {
    font-family: 'Orbitron', monospace;
    font-weight: 900;
    font-size: clamp(2.4rem, 8vw, 5.5rem);
    line-height: 1.05;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    position: relative;
    z-index: 1;
    max-width: 900px;
  }

  .hero h1 em {
    font-style: normal;
    background: linear-gradient(90deg, var(--violet), var(--cyan));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    margin-top: 24px;
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    font-weight: 300;
    color: var(--muted);
    max-width: 520px;
    line-height: 1.6;
    position: relative;
    z-index: 1;
  }

  .hero-actions {
    margin-top: 44px;
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
    position: relative;
    z-index: 1;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--violet), #6B1FBF);
    color: #fff;
    border: none;
    padding: 18px 40px;
    font-family: 'Orbitron', monospace;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    clip-path: polygon(12px 0%, 100% 0%, calc(100% - 12px) 100%, 0% 100%);
    transition: box-shadow 0.3s, transform 0.2s;
    text-decoration: none;
    display: inline-block;
  }
  .btn-primary:hover {
    box-shadow: 0 0 40px var(--glow-v), 0 0 80px rgba(155,48,255,0.15);
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--muted);
    border: 1px solid rgba(255,255,255,0.12);
    padding: 18px 32px;
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: color 0.2s, border-color 0.2s;
  }
  .btn-secondary:hover { color: var(--white); border-color: rgba(255,255,255,0.3); }

  .hero-price-tag {
    position: relative;
    z-index: 1;
    margin-top: 32px;
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 12px;
  }
  .price-old {
    font-size: 1rem;
    color: var(--muted);
    text-decoration: line-through;
  }
  .price-new {
    font-family: 'Orbitron', monospace;
    font-size: 2rem;
    font-weight: 900;
    color: var(--cyan);
  }
  .price-label {
    font-size: 0.75rem;
    color: var(--muted);
    letter-spacing: 0.05em;
  }

  /* ── PROOF STRIP ── */
  .proof-strip {
    background: var(--carbon);
    border-top: 1px solid rgba(155,48,255,0.1);
    border-bottom: 1px solid rgba(155,48,255,0.1);
    padding: 20px 40px;
    display: flex;
    justify-content: center;
    gap: 48px;
    flex-wrap: wrap;
  }
  .proof-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--muted);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .proof-icon {
    width: 28px;
    height: 28px;
    border: 1px solid var(--violet);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  /* ── SECTIONS COMMUNES ── */
  section {
    padding: 90px 24px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-label {
    font-family: 'Orbitron', monospace;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--violet);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .section-label::after { content: ''; flex: 0 0 40px; height: 1px; background: var(--violet); }

  .section-title {
    font-family: 'Orbitron', monospace;
    font-size: clamp(1.6rem, 4vw, 2.6rem);
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1.1;
    max-width: 700px;
  }

  /* ── FEATURES ── */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2px;
    margin-top: 56px;
    background: rgba(155,48,255,0.08);
    border: 1px solid rgba(155,48,255,0.12);
  }

  .feature-card {
    background: var(--panel);
    padding: 36px 32px;
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
  }
  .feature-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--violet), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .feature-card:hover { background: #181828; }
  .feature-card:hover::after { opacity: 1; }

  .feature-number {
    font-family: 'Orbitron', monospace;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--violet-dim);
    margin-bottom: 20px;
  }

  .feature-icon-wrap {
    width: 48px;
    height: 48px;
    background: rgba(155,48,255,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    margin-bottom: 20px;
    border: 1px solid rgba(155,48,255,0.2);
  }

  .feature-title {
    font-family: 'Orbitron', monospace;
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 12px;
    color: var(--white);
  }

  .feature-desc {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.65;
    font-weight: 300;
  }

  /* ── COULEURS DÉMO ── */
  .colors-section {
    background: var(--carbon);
    padding: 90px 24px;
    border-top: 1px solid rgba(0,240,255,0.08);
    border-bottom: 1px solid rgba(0,240,255,0.08);
  }
  .colors-inner { max-width: 1100px; margin: 0 auto; }

  .color-swatches {
    display: flex;
    gap: 12px;
    margin-top: 48px;
    flex-wrap: wrap;
  }

  .swatch {
    flex: 1;
    min-width: 80px;
    height: 100px;
    position: relative;
    cursor: pointer;
    border: 1px solid transparent;
    transition: transform 0.2s, border-color 0.2s;
  }
  .swatch:hover { transform: scaleY(1.06); border-color: rgba(255,255,255,0.3); }
  .swatch-glow {
    position: absolute;
    inset: 0;
    opacity: 0.6;
    transition: opacity 0.3s;
  }
  .swatch:hover .swatch-glow { opacity: 1; }
  .swatch-label {
    position: absolute;
    bottom: -24px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    color: var(--muted);
    white-space: nowrap;
    text-transform: uppercase;
  }

  .color-desc {
    margin-top: 56px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .color-stat {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    background: var(--panel);
    border-left: 2px solid var(--cyan);
  }
  .color-stat-num {
    font-family: 'Orbitron', monospace;
    font-size: 1.8rem;
    font-weight: 900;
    color: var(--cyan);
    line-height: 1;
  }
  .color-stat-label {
    font-size: 0.8rem;
    color: var(--muted);
    line-height: 1.4;
    font-weight: 400;
  }

  /* ── SPECS ── */
  .specs-table {
    margin-top: 48px;
    border: 1px solid rgba(155,48,255,0.15);
    overflow: hidden;
  }
  .spec-row {
    display: grid;
    grid-template-columns: 200px 1fr;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .spec-row:last-child { border-bottom: none; }
  .spec-key {
    padding: 16px 24px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    background: var(--panel);
    border-right: 1px solid rgba(155,48,255,0.1);
  }
  .spec-val {
    padding: 16px 24px;
    font-size: 0.9rem;
    color: var(--white);
    font-weight: 400;
    background: rgba(14,14,24,0.5);
  }
  .spec-val strong { color: var(--cyan); font-weight: 600; }

  /* ── TÉMOIGNAGES ── */
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
    margin-top: 48px;
  }
  .review-card {
    background: var(--panel);
    padding: 28px;
    border: 1px solid rgba(155,48,255,0.1);
    position: relative;
  }
  .review-card::before {
    content: '"';
    position: absolute;
    top: 16px; right: 20px;
    font-family: 'Orbitron', monospace;
    font-size: 3rem;
    color: var(--violet-dim);
    opacity: 0.4;
    line-height: 1;
  }
  .stars { color: var(--violet); font-size: 0.85rem; letter-spacing: 2px; margin-bottom: 14px; }
  .review-text { font-size: 0.9rem; line-height: 1.65; color: #bbbbd8; font-weight: 300; }
  .review-author { margin-top: 18px; font-size: 0.75rem; font-weight: 600; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; }

  /* ── FAQ ── */
  .faq-list { margin-top: 48px; }
  .faq-item {
    border-bottom: 1px solid rgba(255,255,255,0.06);
    padding: 24px 0;
  }
  .faq-q {
    font-family: 'Orbitron', monospace;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--white);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .faq-q::before { content: '?'; font-size: 0.75rem; color: var(--violet); border: 1px solid var(--violet); width: 22px; height: 22px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .faq-a { font-size: 0.9rem; color: var(--muted); line-height: 1.7; font-weight: 300; padding-left: 34px; }

  /* ── CTA FINAL ── */
  .cta-section {
    background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(155,48,255,0.2) 0%, transparent 70%), var(--carbon);
    border-top: 1px solid rgba(155,48,255,0.12);
    padding: 100px 24px;
    text-align: center;
  }
  .cta-inner { max-width: 700px; margin: 0 auto; }
  .cta-inner .section-label { justify-content: center; }
  .cta-inner .section-label::after { display: none; }
  .cta-title {
    font-family: 'Orbitron', monospace;
    font-size: clamp(1.8rem, 5vw, 3rem);
    font-weight: 900;
    text-transform: uppercase;
    margin-top: 16px;
    margin-bottom: 20px;
  }
  .cta-title em {
    font-style: normal;
    background: linear-gradient(90deg, var(--violet), var(--cyan));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .cta-sub { font-size: 1rem; color: var(--muted); font-weight: 300; line-height: 1.6; margin-bottom: 44px; }

  .cta-bundle {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    background: var(--panel);
    border: 1px solid rgba(155,48,255,0.25);
    padding: 32px 48px;
    margin-bottom: 32px;
  }
  .cta-bundle-name { font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); margin-bottom: 8px; }
  .cta-bundle-price { font-family: 'Orbitron', monospace; font-size: 2.8rem; font-weight: 900; color: var(--cyan); }
  .cta-bundle-detail { font-size: 0.8rem; color: var(--muted); margin-top: 6px; }

  .cta-guarantee {
    margin-top: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: 0.8rem;
    color: var(--muted);
  }
  .cta-guarantee::before { content: '🔒'; }

  /* ── FOOTER ── */
  footer {
    background: var(--void);
    border-top: 1px solid rgba(255,255,255,0.05);
    padding: 40px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: gap;
    gap: 20px;
  }
  .footer-logo { font-family: 'Orbitron', monospace; font-weight: 900; font-size: 1rem; }
  .footer-logo span { color: var(--violet); }
  .footer-links { display: flex; gap: 24px; flex-wrap: wrap; }
  .footer-links a { font-size: 0.78rem; color: var(--muted); text-decoration: none; letter-spacing: 0.05em; transition: color 0.2s; }
  .footer-links a:hover { color: var(--white); }
  .footer-copy { font-size: 0.72rem; color: rgba(122,122,154,0.5); }

  /* ── SCROLL REVEAL ── */
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.7s ease, transform 0.7s ease; }
  .revealed { opacity: 1; transform: translateY(0); }

  /* ── RESPONSIVE ── */
  @media (max-width: 640px) {
    nav { padding: 16px 20px; }
    .proof-strip { gap: 24px; padding: 20px; }
    .color-desc { grid-template-columns: 1fr; }
    .spec-row { grid-template-columns: 1fr; }
    .spec-key { border-right: none; border-bottom: 1px solid rgba(155,48,255,0.1); }
    footer { flex-direction: column; text-align: center; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-bg, .badge::before { animation: none; }
    .reveal { opacity: 1; transform: none; }
  }
</style>

